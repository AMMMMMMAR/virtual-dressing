msgid "Please enter a valid height (100-250 cm) before processing."
msgstr "يرجى إدخال طول صحيح (100-250 سم) قبل المعالجة."

msgid "required – close-up face for skin tone"
msgstr "مطلوب – صورة مقرّبة للوجه لتحليل لون البشرة"

msgid "required – full body, front view"
msgstr "مطلوب – الجسم كاملًا، من الأمام"

msgid "Drag to rotate · Scroll to zoom"
msgstr "اسحب للتدوير · مرر للتكبير/التصغير"

msgid "A timeless classic cotton shirt perfect for any occasion. Made from 100% premium cotton for maximum comfort and breathability."
msgstr "قميص قطني كلاسيكي خالد مناسب لكل المناسبات. مصنوع من قطن فاخر 100% لراحة وتهوية قصوى."

msgid "Comfortable denim jeans with a classic fit. Durable and stylish for everyday wear with premium denim fabric."
msgstr "جينز دنيم مريح بقصّة كلاسيكية. متين وأنيق للاستخدام اليومي بقماش دنيم فاخر."

msgid "Premium leather jacket with a classic design. Timeless piece that never goes out of style, crafted from genuine leather."
msgstr "جاكيت جلدي فاخر بتصميم كلاسيكي. قطعة خالدة لا تخرج من الموضة، مصنوعة من جلد طبيعي."

msgid "Sophisticated blouse with delicate details. Perfect for both office and evening wear with premium silk-like fabric."
msgstr "بلوزة أنيقة بتفاصيل ناعمة. مثالية للعمل والمساء بقماش فاخر شبيه بالحرير."

msgid "Relaxed oversized blouse with an elegant drape. Perfect for casual or smart-casual occasions with lightweight breathable fabric."
msgstr "بلوزة واسعة ومريحة بانسيابية أنيقة. مثالية للمناسبات الكاجوال أو شبه الرسمية بقماش خفيف وقابل للتنفس."

msgid "Tailored slim trousers with a flattering silhouette. Versatile for office or casual settings with a premium fabric blend."
msgstr "بنطال ضيق مفصّل بقصة تبرز القوام. مناسب للعمل أو الإطلالات الكاجوال بخليط قماش فاخر."

